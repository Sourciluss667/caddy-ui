}

jellyfin.local.example.test {
	header {
		Strict-Transport-Security "max-age=31536000"
	}
	reverse_proxy http://192.0.2.14:8096 {
		flush_interval -1
		stream_timeout 36000s
		stream_close_delay 5m
	}
}

jellyfin.example.test {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "SAMEORIGIN"
		X-XSS-Protection "0"
		X-Content-Type-Options "nosniff"
		Content-Security-Policy "default-src 'self' https: data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; worker-src 'self' blob:; object-src 'none'; frame-ancestors 'self'"
	}
	reverse_proxy http://192.0.2.14:8096 {
		flush_interval -1
		stream_timeout 36000s
		stream_close_delay 5m
	}
}

jellyfin-dev.example.test {
