webhook-n8n.sourciluss.cloud {
	header {
		Strict-Transport-Security "max-age=31536000"
	}
	@webhook_paths path /webhook/* /webhook-test/*
	handle @webhook_paths {
		reverse_proxy http://192.168.1.182:5678
	}

	handle {
		respond 403
	}
}

