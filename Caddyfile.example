webhook-n8n.example.test {
	header {
		Strict-Transport-Security "max-age=31536000"
	}
	@webhook_paths path /webhook/* /webhook-test/*
	handle @webhook_paths {
		reverse_proxy http://192.0.2.28:5678
	}

	handle {
		respond 403
	}
}

