{
	email admin@example.test
	acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
}

nginx.local.example.test {
	header {
		Strict-Transport-Security "max-age=31536000"
	}
	reverse_proxy http://192.0.2.10:81
}

omv.local.example.test {
	header {
		Strict-Transport-Security "max-age=31536000"
	}
	reverse_proxy http://192.0.2.11:80
}

proxmox.local.example.test, pve.local.example.test {
	header {
		Strict-Transport-Security "max-age=31536000"
	}
	reverse_proxy https://192.0.2.12:8006 {
		transport http {
			tls_insecure_skip_verify
		}
	}
}

homarr.local.example.test, local.example.test {
